# FloorCalc Pro environment example.
# Copy this file to .env.local for local development and set real values there.
# Never commit real secrets.

# Public canonical site URL used for metadata, sitemap, and robots.
NEXT_PUBLIC_SITE_URL=https://www.floorcalcpro.net

# Solo-admin password for /admin.
# Use a long, random password. Do not reuse a personal password.
ADMIN_PASSWORD=

# Secret used to sign the admin session cookie.
# Use a separate long, random value from ADMIN_PASSWORD.
ADMIN_SESSION_SECRET=

# Optional analytics. Leave as "none" or unset to disable tracking.
# Supported placeholders: plausible, google-analytics.
NEXT_PUBLIC_ANALYTICS_PROVIDER=none

# Required only if NEXT_PUBLIC_ANALYTICS_PROVIDER=plausible.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Required only if NEXT_PUBLIC_ANALYTICS_PROVIDER=google-analytics.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
